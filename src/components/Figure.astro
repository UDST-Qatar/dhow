---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type Aspect = 'auto' | 'video' | 'square' | '4/3' | '3/2' | '5/4';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  number?: string;
  /** When set, the image sits in a fixed-aspect frame and is contained — used to keep figure cards uniform across mixed source aspect ratios. */
  aspect?: Aspect;
  /** Plain frame (no padding around image). Set false for product/CAD shots that need breathing room. */
  flush?: boolean;
}

const { src, alt, caption, number, aspect = 'auto', flush = false } = Astro.props;

const aspectClass: Record<Aspect, string> = {
  auto: '',
  video: 'aspect-video',
  square: 'aspect-square',
  '4/3': 'aspect-[4/3]',
  '3/2': 'aspect-[3/2]',
  '5/4': 'aspect-[5/4]',
};

const fixed = aspect !== 'auto';
const frameClass = [
  'overflow-hidden rounded-md border border-[color:var(--color-rule)] bg-white',
  fixed ? `${aspectClass[aspect]} flex items-center justify-center` : '',
  fixed && !flush ? 'p-5' : '',
].filter(Boolean).join(' ');
---

<figure class="my-2">
  <div class={frameClass}>
    <Image
      src={src}
      alt={alt}
      widths={[480, 768, 1200, 1600]}
      sizes="(min-width: 1024px) 720px, (min-width: 640px) 88vw, 92vw"
      class={fixed ? 'max-h-full max-w-full w-auto h-auto object-contain' : 'w-full h-auto'}
      loading="lazy"
      decoding="async"
    />
  </div>
  {(caption || number) && (
    <figcaption class="mt-3 text-xs text-[color:var(--color-ink-muted)] flex gap-2 leading-relaxed">
      {number && <span class="font-medium text-[color:var(--color-ink-soft)] shrink-0">{number}</span>}
      {caption && <span>{caption}</span>}
    </figcaption>
  )}
</figure>
