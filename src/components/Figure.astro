---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  number?: string;
  contain?: boolean;
}

const { src, alt, caption, number, contain = false } = Astro.props;
---

<figure class="my-2">
  <div class={`overflow-hidden rounded-md border border-[color:var(--color-rule)] bg-[color:var(--color-paper-soft)] ${contain ? 'p-6' : ''}`}>
    <Image
      src={src}
      alt={alt}
      widths={[480, 768, 1200, 1600]}
      sizes="(min-width: 1024px) 720px, (min-width: 640px) 88vw, 92vw"
      class={contain ? 'mx-auto max-h-[480px] object-contain' : 'w-full h-auto'}
      loading="lazy"
      decoding="async"
    />
  </div>
  {(caption || number) && (
    <figcaption class="mt-3 text-sm text-[color:var(--color-ink-muted)] flex gap-2">
      {number && <span class="font-medium text-[color:var(--color-ink-soft)]">{number}</span>}
      {caption && <span>{caption}</span>}
    </figcaption>
  )}
</figure>
