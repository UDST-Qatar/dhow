---
const today = new Date();
---

<footer class="relative overflow-hidden text-white" style="background: linear-gradient(180deg, #003E87 0%, #0055B8 100%);">
  <!-- Subtle UDST monogram watermark on the right -->
  <svg
    class="absolute -right-12 -bottom-16 h-[420px] w-auto opacity-[0.06] pointer-events-none select-none"
    viewBox="0 0 33 46"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      d="M6.05 8.75v13.427l8.749 7.37V8.75l-2.87 2.447v12.578l-2.94-2.393V11.197zM14.799 46V32.58L6.05 25.21V46l2.87-2.44V30.981l2.939 2.393v10.184zm2.773-37.25v20.797l8.755-7.37V8.75h-8.755zm5.816 12.632-2.94 2.413V11.197h2.94v10.185zM3.043 4.242h26.915v2.502H3.043zm26.914-1.74H3.043L0 0h33zM23.45 43.56 26.327 46v-3.168l-2.877-2.448v3.175zm-5.878-10.98V46l2.939-2.44v-10.2l2.939-2.393v8.396l2.877 2.448V25.21l-8.755 7.37z"
      fill="white"
    />
  </svg>

  <div class="relative mx-auto max-w-[var(--container-wide)] px-6 lg:px-10 pt-20 pb-12">
    <!-- Masthead -->
    <div class="grid lg:grid-cols-[auto_1fr] gap-10 lg:gap-16 items-end">
      <img
        src={`${import.meta.env.BASE_URL}brand/udst-full.svg`}
        alt="University of Doha for Science and Technology"
        width="196"
        height="97"
        class="h-16 w-auto"
        style="filter: brightness(0) invert(1);"
      />
      <div class="text-right lg:text-right">
        <p
          lang="ar"
          class="font-serif text-lg lg:text-xl text-white/75 leading-snug"
        >
          التحديث المستدام للمراكب الخشبية التقليدية في قطر
        </p>
        <p class="font-serif text-2xl lg:text-3xl text-white leading-tight mt-1 tracking-tight">
          Sustainable Dhows · Retrofitting in Qatar
        </p>
      </div>
    </div>

    <hr class="border-0 border-t border-white/15 mt-14" />

    <!-- Info columns -->
    <div class="grid md:grid-cols-3 gap-10 mt-12">
      <div>
        <p class="text-[11px] uppercase tracking-[0.16em] text-white/60 font-medium">Project leadership</p>
        <ul class="mt-4 space-y-3.5">
          <li>
            <p class="text-sm text-white">Dr. Hassan Mahasneh</p>
            <p class="text-xs text-white/65 mt-0.5">Lead PI · Telecomm. Engineering</p>
          </li>
          <li>
            <p class="text-sm text-white">Dr. Wesam Rohouma</p>
            <p class="text-xs text-white/65 mt-0.5">PI · Electrical Engineering</p>
          </li>
          <li>
            <p class="text-sm text-white">Dr. Nagi Abdussamie</p>
            <p class="text-xs text-white/65 mt-0.5">PI · Marine Engineering</p>
          </li>
        </ul>
      </div>

      <div>
        <p class="text-[11px] uppercase tracking-[0.16em] text-white/60 font-medium">Recipient</p>
        <p class="mt-4 text-sm text-white leading-relaxed">
          Ministry of Environment and Climate Change
        </p>
        <p class="text-xs text-white/65 mt-1">Green Development &amp; Environmental Sustainability</p>
        <div class="mt-5">
          <p class="text-sm text-white">Dr. Adeeb Ali</p>
          <a href="mailto:aakutty@mecc.gov.qa" class="font-mono text-[11px] text-white/70 hover:text-white transition-colors mt-0.5 inline-block">
            aakutty@mecc.gov.qa
          </a>
        </div>
      </div>

      <div>
        <p class="text-[11px] uppercase tracking-[0.16em] text-white/60 font-medium">Report</p>
        <ul class="mt-4 space-y-3 text-sm">
          <li class="flex justify-between gap-3 border-b border-white/10 pb-2.5">
            <span class="text-white/65">Number</span>
            <span class="text-white tabular">MOECC-UDST-5</span>
          </li>
          <li class="flex justify-between gap-3 border-b border-white/10 pb-2.5">
            <span class="text-white/65">Version</span>
            <span class="text-white">A — Progress</span>
          </li>
          <li class="flex justify-between gap-3 border-b border-white/10 pb-2.5">
            <span class="text-white/65">Issued</span>
            <span class="text-white tabular">26 Jan 2026</span>
          </li>
          <li class="flex justify-between gap-3">
            <span class="text-white/65">Phase</span>
            <span class="text-white">3 / 4 · Prototype</span>
          </li>
        </ul>
      </div>
    </div>

    <hr class="border-0 border-t border-white/15 mt-14" />

    <!-- Bottom strip -->
    <div class="mt-6 flex flex-col md:flex-row gap-3 justify-between text-xs">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-white/60">
        <span>Aligned with Qatar National Vision 2030</span>
        <span aria-hidden="true">·</span>
        <span>Safety paper accepted at OMAE 2026, Tokyo</span>
      </div>
      <span class="text-white/60">© {today.getFullYear()} UDST Research</span>
    </div>
  </div>
</footer>
