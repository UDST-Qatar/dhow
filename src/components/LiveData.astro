---
/**
 * Live telemetry dashboard — pulls the published Google Sheet (inverter + AC tabs),
 * caches client-side, and renders an editorial dashboard with source tabs.
 *
 * Build time: fetches both sheets once, embeds parsed snapshots for instant first paint.
 * Runtime: SWR — serves cached data immediately, revalidates every 5 min.
 */
import {
  parseCsv,
  rowsToSamples,
  rowsToAcSamples,
  type Sample,
  type AcSample,
} from '../lib/sheet';
import ChartFrame from './ChartFrame.astro';

const DEFAULT_SHEET_ID = '1k4iWLhBqlMpo_RNDu7yGBHmwPwlI_iuQl2x3WNkN_Wk';
const SHEET_ID = import.meta.env.PUBLIC_SHEET_ID ?? DEFAULT_SHEET_ID;

const inverterUrl = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=inverter1`;
const acUrl       = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=ac_unit1`;

let inverter: Sample[] = [];
let ac: AcSample[] = [];
let fetchedAt: number | null = null;

try {
  const [invRes, acRes] = await Promise.all([
    fetch(inverterUrl, { signal: AbortSignal.timeout(10_000) }),
    fetch(acUrl, { signal: AbortSignal.timeout(10_000) }),
  ]);
  if (invRes.ok) inverter = rowsToSamples(parseCsv(await invRes.text()));
  if (acRes.ok)  ac = rowsToAcSamples(parseCsv(await acRes.text()));
  fetchedAt = Date.now();
} catch {
  // build-time fetch failure is non-fatal — runtime will retry
}

const initialPayload = JSON.stringify({ fetchedAt, inverter, ac });
---

<div
  id="live-dashboard"
  class="not-prose"
  data-inverter-url={inverterUrl}
  data-ac-url={acUrl}
>
  <script type="application/json" id="live-initial" set:html={initialPayload}></script>

  <!-- Toolbar: source tabs · status · range tabs · last-updated -->
  <header class="grid gap-3 mb-5">
    <div class="flex flex-wrap items-center gap-3">
      <div role="tablist" aria-label="Data source" class="inline-flex rounded-md border border-[color:var(--color-rule)] bg-white overflow-hidden text-sm font-medium" data-source-tabs>
        {([
          { id: 'inverter', label: 'Inverter', sub: 'solar · battery · load' },
          { id: 'ac',       label: 'AC unit',  sub: 'cabin temperature' },
        ] as const).map((t) => (
          <button
            type="button"
            role="tab"
            data-source={t.id}
            class="px-4 py-2 flex flex-col items-start text-left text-[color:var(--color-ink-soft)] data-[active=true]:bg-[color:var(--color-udst-blue)] data-[active=true]:text-white transition-colors"
          >
            <span class="leading-tight">{t.label}</span>
            <span class="text-[10px] uppercase tracking-[0.1em] opacity-70 leading-tight mt-0.5">{t.sub}</span>
          </button>
        ))}
      </div>

      <div class="flex items-center gap-2.5 ml-auto">
        <span class="relative flex h-2 w-2" data-status-dot>
          <span class="absolute inline-flex h-full w-full rounded-full bg-[color:var(--color-udst-blue)] opacity-50 animate-ping"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-[color:var(--color-udst-blue)]"></span>
        </span>
        <span class="text-xs text-[color:var(--color-ink-muted)] tabular" data-status>—</span>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <div role="tablist" aria-label="Time range" class="inline-flex rounded-md border border-[color:var(--color-rule)] bg-white overflow-hidden text-xs font-medium" data-range-tabs>
        {(['24h', '7d', '30d', 'all'] as const).map((r) => (
          <button
            type="button"
            role="tab"
            data-range={r}
            class="px-3 py-1.5 text-[color:var(--color-ink-soft)] data-[active=true]:bg-[color:var(--color-udst-blue)] data-[active=true]:text-white transition-colors"
          >
            {r === 'all' ? 'All' : r.toUpperCase()}
          </button>
        ))}
      </div>
      <div class="text-xs text-[color:var(--color-ink-muted)] tabular ml-auto" data-last-updated>—</div>
    </div>
  </header>

  <!-- Inverter panel -->
  <div data-panel="inverter">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-px bg-[color:var(--color-rule)] rounded-lg overflow-hidden border border-[color:var(--color-rule)] mb-6" data-cards-inverter></div>

    <div class="grid lg:grid-cols-[1.6fr_1fr] gap-6 mb-6">
      <ChartFrame id="chart-battery" title="Battery state" subtitle="Charge percentage." />
      <ChartFrame id="chart-pv" title="Solar generation" subtitle="PV1 power output." />
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      <ChartFrame id="chart-temps" title="Heatsink temperatures" subtitle="Inverter, MPPT, and DC-DC heatsinks (°C)." />
      <ChartFrame id="chart-load" title="Load power" subtitle="Onboard load draw (W)." />
    </div>
  </div>

  <!-- AC unit panel -->
  <div data-panel="ac" hidden>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-px bg-[color:var(--color-rule)] rounded-lg overflow-hidden border border-[color:var(--color-rule)] mb-6" data-cards-ac></div>

    <div class="mb-6">
      <ChartFrame id="chart-cabin" title="Cabin temperature" subtitle="Internal cabin temp vs. cool setpoint (dashed)." height={280} />
    </div>

    <div>
      <ChartFrame id="chart-delta" title="Comfort delta" subtitle="Cabin temp − setpoint. Above zero = cooling deficit." height={200} />
    </div>
  </div>

  <p class="mt-5 text-xs text-[color:var(--color-ink-muted)] flex flex-wrap items-center gap-x-3 gap-y-1">
    <span>Source: published Google Sheet · two tabs (inverter · ac_unit)</span>
    <span aria-hidden="true">·</span>
    <span>Cache TTL 5 min · cache-first SWR</span>
    <span aria-hidden="true">·</span>
    <a href={`https://docs.google.com/spreadsheets/d/${SHEET_ID}/edit`} target="_blank" rel="noopener" class="underline decoration-dotted hover:text-[color:var(--color-udst-blue)]">Open spreadsheet →</a>
  </p>
</div>

<script>
  import { Chart, type Series } from '../lib/chart';
  import {
    filterRange, downsample, downsampleAc, deriveStats, deriveAcStats,
    loadInverterSheet, loadAcSheet,
    type Sample, type AcSample, type Range,
  } from '../lib/sheet';

  type Source = 'inverter' | 'ac';
  type Initial = { fetchedAt: number | null; inverter: Sample[]; ac: AcSample[] };

  const COLOR = {
    blue: '#0055B8',
    blueDeep: '#003E87',
    forest: '#1f6f4a',
    slate: '#475569',
    violet: '#5b3b8c',
  };

  const fmtPower = (v: number) => v >= 1000 ? (v / 1000).toFixed(1) + 'kW' : v.toFixed(0) + 'W';
  const fmtPct = (v: number) => `${v.toFixed(0)}%`;
  const fmtTemp = (v: number) => `${v.toFixed(0)}°`;
  const fmtTempPrecise = (v: number) => `${v.toFixed(1)}°C`;
  const fmtKwh = (n: number) => n >= 1000 ? (n / 1000).toFixed(1) + ' MWh' : n.toFixed(1) + ' kWh';
  const fmtNum = (n: number, d = 0) => Math.abs(n) >= 10000 ? (n / 1000).toFixed(1) + 'k' : n.toFixed(d);
  const fmtTimeAgo = (ms: number) => {
    const s = Math.round((Date.now() - ms) / 1000);
    if (s < 60) return `${s}s ago`;
    if (s < 3600) return `${Math.round(s / 60)}m ago`;
    if (s < 86400) return `${Math.round(s / 3600)}h ago`;
    return `${Math.round(s / 86400)}d ago`;
  };

  function readInitial(): Initial {
    const el = document.getElementById('live-initial');
    if (!el?.textContent) return { fetchedAt: null, inverter: [], ac: [] };
    try { return JSON.parse(el.textContent); } catch { return { fetchedAt: null, inverter: [], ac: [] }; }
  }

  // ---- Card render helpers ----
  function renderCardGrid(root: HTMLElement, cards: { label: string; value: string; sub?: string; tone?: 'default' | 'accent' }[]) {
    root.innerHTML = cards.map(c => {
      const accent = c.tone === 'accent';
      const cls = accent ? 'p-5 bg-[color:var(--color-udst-blue)] text-white' : 'p-5 bg-white';
      const labelCls = accent
        ? 'text-[11px] uppercase tracking-[0.1em] text-white/70'
        : 'text-[11px] uppercase tracking-[0.1em] text-[color:var(--color-ink-muted)]';
      const valCls = accent
        ? 'mt-1 font-serif text-2xl tabular'
        : 'mt-1 font-serif text-2xl text-[color:var(--color-ink)] tabular';
      const subCls = accent
        ? 'mt-0.5 text-xs text-white/70'
        : 'mt-0.5 text-xs text-[color:var(--color-ink-muted)]';
      return `<div class="${cls}">
        <div class="${labelCls}">${c.label}</div>
        <div class="${valCls}">${c.value}</div>
        ${c.sub ? `<div class="${subCls}">${c.sub}</div>` : ''}
      </div>`;
    }).join('');
  }

  function renderInverterCards(latest: Sample, stats: ReturnType<typeof deriveStats>) {
    const root = document.querySelector<HTMLElement>('[data-cards-inverter]');
    if (!root) return;
    const shore = latest.acInV > 50;
    renderCardGrid(root, [
      { label: 'Battery', value: `${latest.batteryV.toFixed(2)} V`, sub: `${latest.batteryPct.toFixed(0)}% state of charge`, tone: 'accent' },
      { label: 'PV power', value: `${fmtNum(latest.pv1W, 0)} W`, sub: `peak in window: ${fmtNum(stats.peakPvW, 0)} W` },
      { label: 'Load draw', value: `${fmtNum(latest.loadW, 0)} W`, sub: `${latest.loadA.toFixed(2)} A` },
      { label: 'AC bus', value: `${latest.acOutV.toFixed(0)} V`, sub: shore ? `shore power ${latest.acInV.toFixed(0)} V in` : 'shore power disconnected' },
      { label: 'Heatsinks', value: `${latest.invTemp.toFixed(1)}°`, sub: `inv · MPPT ${latest.mpptTemp.toFixed(1)}° · DC-DC ${latest.dcdcTemp.toFixed(1)}°` },
      { label: 'Energy harvested', value: fmtKwh(stats.totalEnergyKwh), sub: `over ${stats.daysCovered.toFixed(1)} days in window` },
      { label: 'Avg battery SOC', value: `${stats.avgBattPct.toFixed(0)}%`, sub: `peak discharge ${fmtNum(stats.peakBattW, 0)} W` },
      { label: 'Load energy', value: fmtKwh(stats.loadEnergyKwh), sub: 'integrated in window' },
    ]);
  }

  function renderAcCards(stats: ReturnType<typeof deriveAcStats>) {
    const root = document.querySelector<HTMLElement>('[data-cards-ac]');
    if (!root) return;
    const delta = stats.current - stats.setPoint;
    const deltaSign = delta > 0.1 ? '+' : delta < -0.1 ? '' : '±';
    renderCardGrid(root, [
      { label: 'Cabin temp', value: fmtTempPrecise(stats.current), sub: `${deltaSign}${delta.toFixed(1)}° vs. setpoint`, tone: 'accent' },
      { label: 'Setpoint', value: fmtTempPrecise(stats.setPoint), sub: stats.setPointChanges === 0 ? 'unchanged in window' : `${stats.setPointChanges} change${stats.setPointChanges === 1 ? '' : 's'} in window` },
      { label: 'Avg cabin', value: fmtTempPrecise(stats.avg) },
      { label: 'Range', value: `${stats.min.toFixed(1)} – ${stats.max.toFixed(1)}°`, sub: 'min / max in window' },
      { label: 'Comfort time', value: `${stats.comfortPct.toFixed(0)}%`, sub: 'within ±1° of setpoint' },
      { label: 'Cooling deficit', value: `${stats.degreeHoursAbove.toFixed(0)} °C·h`, sub: '∫ max(0, cabin − set) dt' },
    ]);
  }

  // ---- Charts ----
  const charts = {
    battery: null as Chart | null,
    pv:      null as Chart | null,
    temps:   null as Chart | null,
    load:    null as Chart | null,
    cabin:   null as Chart | null,
    delta:   null as Chart | null,
  };

  function ensureCharts() {
    const host = (id: string) => document.querySelector<HTMLElement>(`#${id} .chart-host`);
    const w = 640;
    if (!charts.battery) { const h = host('chart-battery'); if (h) charts.battery = new Chart(h, { width: w, height: 240, yMin: 0, yMax: 100, yFormat: fmtPct }); }
    if (!charts.pv)      { const h = host('chart-pv');      if (h) charts.pv      = new Chart(h, { width: w, height: 240, yMinForceZero: true, yFormat: fmtPower }); }
    if (!charts.temps)   { const h = host('chart-temps');   if (h) charts.temps   = new Chart(h, { width: w, height: 220, yFormat: fmtTemp }); }
    if (!charts.load)    { const h = host('chart-load');    if (h) charts.load    = new Chart(h, { width: w, height: 220, yMinForceZero: true, yFormat: fmtPower }); }
    if (!charts.cabin)   { const h = host('chart-cabin');   if (h) charts.cabin   = new Chart(h, { width: w, height: 280, yFormat: fmtTemp }); }
    if (!charts.delta)   { const h = host('chart-delta');   if (h) charts.delta   = new Chart(h, { width: w, height: 200, yFormat: (v: number) => `${v.toFixed(1)}°` }); }
  }

  function renderInverterCharts(samples: Sample[], range: Range) {
    const filtered = filterRange(samples, range);
    if (filtered.length < 2) return;
    const ds = downsample(filtered, 240);

    charts.battery?.setData([
      { label: 'State of charge', color: COLOR.blue, fill: true,
        data: ds.map(s => [s.ts, s.batteryPct] as [number, number]) },
    ]);
    charts.pv?.setData([
      { label: 'PV1 power', color: COLOR.forest, fill: true,
        data: ds.map(s => [s.ts, s.pv1W] as [number, number]) },
    ]);
    charts.temps?.setData([
      { label: 'Inverter', color: COLOR.blue,   data: ds.map(s => [s.ts, s.invTemp]  as [number, number]) },
      { label: 'MPPT',     color: COLOR.forest, data: ds.map(s => [s.ts, s.mpptTemp] as [number, number]) },
      { label: 'DC-DC',    color: COLOR.slate,  data: ds.map(s => [s.ts, s.dcdcTemp] as [number, number]) },
    ]);
    charts.load?.setData([
      { label: 'Load', color: COLOR.violet, fill: true,
        data: ds.map(s => [s.ts, s.loadW] as [number, number]) },
    ]);
  }

  function renderAcCharts(samples: AcSample[], range: Range) {
    const filtered = filterRange(samples, range);
    if (filtered.length < 2) return;
    const ds = downsampleAc(filtered, 240);

    charts.cabin?.setData([
      { label: 'Cabin temp', color: COLOR.blue,
        data: ds.map(s => [s.ts, s.cabinTemp] as [number, number]) },
      { label: 'Setpoint', color: COLOR.slate, dashed: true,
        data: ds.map(s => [s.ts, s.setPoint] as [number, number]) },
    ]);
    charts.delta?.setData([
      { label: 'Cabin − setpoint', color: COLOR.violet, fill: true,
        data: ds.map(s => [s.ts, s.cabinTemp - s.setPoint] as [number, number]) },
    ]);
  }

  // ---- Render orchestration ----
  let state: { source: Source; range: Range; inverter: Sample[]; ac: AcSample[]; fetchedAt: number } = {
    source: 'inverter',
    range: '24h',
    inverter: [],
    ac: [],
    fetchedAt: Date.now(),
  };

  function syncPanels() {
    document.querySelectorAll<HTMLElement>('[data-panel]').forEach(p => {
      p.hidden = p.dataset.panel !== state.source;
    });
    document.querySelectorAll<HTMLElement>('[data-source-tabs] [data-source]').forEach(b => {
      b.dataset.active = (b.dataset.source === state.source) ? 'true' : 'false';
    });
    document.querySelectorAll<HTMLElement>('[data-range-tabs] [data-range]').forEach(b => {
      b.dataset.active = (b.dataset.range === state.range) ? 'true' : 'false';
    });
  }

  function updateLastUpdated(latest: { ts: number } | undefined) {
    const lu = document.querySelector<HTMLElement>('[data-last-updated]');
    if (!lu) return;
    if (!latest) { lu.textContent = '—'; return; }
    const sampleDate = new Date(latest.ts * 1000).toLocaleString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    lu.textContent = `latest sample ${sampleDate} · synced ${fmtTimeAgo(state.fetchedAt)}`;
  }

  function renderActive() {
    ensureCharts();
    if (state.source === 'inverter' && state.inverter.length >= 2) {
      const filtered = filterRange(state.inverter, state.range);
      const stats = deriveStats(filtered);
      renderInverterCards(state.inverter[state.inverter.length - 1], stats);
      renderInverterCharts(state.inverter, state.range);
      updateLastUpdated(state.inverter[state.inverter.length - 1]);
    } else if (state.source === 'ac' && state.ac.length >= 2) {
      const filtered = filterRange(state.ac, state.range);
      const stats = deriveAcStats(filtered);
      renderAcCards(stats);
      renderAcCharts(state.ac, state.range);
      updateLastUpdated(state.ac[state.ac.length - 1]);
    }
  }

  function setStatus(text: string, ok: boolean) {
    const s = document.querySelector<HTMLElement>('[data-status]');
    const dot = document.querySelector<HTMLElement>('[data-status-dot] span:last-child');
    if (s) s.textContent = text;
    if (dot) dot.style.background = ok ? 'var(--color-udst-blue)' : 'var(--color-warning)';
  }

  // ---- bootstrap ----
  function init() {
    const root = document.getElementById('live-dashboard');
    if (!root) return;
    const inverterUrl = root.dataset.inverterUrl ?? '';
    const acUrl = root.dataset.acUrl ?? '';

    const initial = readInitial();
    if (initial.inverter.length || initial.ac.length) {
      state.inverter = initial.inverter;
      state.ac = initial.ac;
      state.fetchedAt = initial.fetchedAt ?? Date.now();
      setStatus(`baked-in snapshot (${initial.inverter.length.toLocaleString()} + ${initial.ac.length.toLocaleString()})`, true);
    } else {
      setStatus('connecting…', true);
    }

    syncPanels();
    renderActive();

    document.querySelectorAll<HTMLElement>('[data-source-tabs] [data-source]').forEach(btn => {
      btn.addEventListener('click', () => {
        state.source = btn.dataset.source as Source;
        syncPanels();
        renderActive();
      });
    });
    document.querySelectorAll<HTMLElement>('[data-range-tabs] [data-range]').forEach(btn => {
      btn.addEventListener('click', () => {
        state.range = btn.dataset.range as Range;
        syncPanels();
        renderActive();
      });
    });

    // SWR — fetch both sheets in parallel and revalidate
    let revalidating = false;
    const revalidate = async () => {
      if (revalidating) return;
      revalidating = true;
      try {
        await Promise.all([
          inverterUrl ? loadInverterSheet(inverterUrl, (data, info) => {
            state.inverter = data;
            state.fetchedAt = info.fetchedAt;
            if (state.source === 'inverter') renderActive();
          }) : Promise.resolve(),
          acUrl ? loadAcSheet(acUrl, (data, info) => {
            state.ac = data;
            state.fetchedAt = info.fetchedAt;
            if (state.source === 'ac') renderActive();
          }) : Promise.resolve(),
        ]);
        setStatus(`live · ${state.inverter.length.toLocaleString()} inv + ${state.ac.length.toLocaleString()} ac`, true);
      } catch (err) {
        setStatus(`fetch failed: ${(err as Error).message}`, false);
      } finally {
        revalidating = false;
      }
    };

    revalidate();
    setInterval(revalidate, 5 * 60 * 1000);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') revalidate();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
