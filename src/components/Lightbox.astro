---
/**
 * Singleton lightbox / image gallery.
 *
 * Mounted once in BaseLayout. Picks up every `[data-lb]` element on the page
 * (currently emitted by `<Figure>`), treats them as a single ordered gallery,
 * and lets the user step through with keyboard, click, or swipe.
 */
---

<div
  id="lightbox"
  hidden
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
  class="fixed inset-0 z-[100] opacity-0 pointer-events-none transition-opacity duration-200"
  data-state="closed"
>
  <!-- Backdrop -->
  <div
    data-lb-backdrop
    class="absolute inset-0 bg-[#0b0d12]/92 backdrop-blur-md"
  ></div>

  <!-- Top bar: counter + close -->
  <div class="absolute top-0 left-0 right-0 flex items-center justify-between p-4 lg:p-6 z-10">
    <span
      id="lb-counter"
      class="font-mono text-xs tracking-[0.18em] uppercase text-white/65 tabular"
    >—</span>
    <button
      type="button"
      data-lb-close
      aria-label="Close"
      class="group flex items-center gap-2 px-3 py-2 rounded-full bg-white/10 hover:bg-white/20 text-white text-xs font-medium transition-colors"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <path d="M2 2 L12 12 M12 2 L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <span class="hidden sm:inline">Close</span>
      <kbd class="hidden lg:inline font-mono text-[10px] opacity-60 ml-1">Esc</kbd>
    </button>
  </div>

  <!-- Prev / Next -->
  <button
    type="button"
    data-lb-prev
    aria-label="Previous image"
    class="absolute left-3 lg:left-6 top-1/2 -translate-y-1/2 z-10 w-11 h-11 lg:w-14 lg:h-14 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-colors"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 6l-6 6 6 6"/>
    </svg>
  </button>
  <button
    type="button"
    data-lb-next
    aria-label="Next image"
    class="absolute right-3 lg:right-6 top-1/2 -translate-y-1/2 z-10 w-11 h-11 lg:w-14 lg:h-14 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-colors"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 6l6 6-6 6"/>
    </svg>
  </button>

  <!-- Image stage -->
  <div class="absolute inset-0 flex items-center justify-center p-14 lg:p-20" data-lb-stage>
    <img
      id="lb-img"
      alt=""
      class="max-h-full max-w-full object-contain shadow-[0_30px_80px_-20px_rgba(0,0,0,0.6)] opacity-0 transition-opacity duration-150"
      decoding="async"
    />
  </div>

  <!-- Caption -->
  <div class="absolute bottom-0 left-0 right-0 p-4 lg:p-6 z-10">
    <p id="lb-caption" class="text-center text-sm text-white/85 max-w-3xl mx-auto leading-relaxed text-pretty"></p>
  </div>
</div>

<script>
  type Item = {
    el: HTMLElement;
    src: string;
    alt: string;
    caption: string;
  };

  const root = document.getElementById('lightbox') as HTMLDivElement;
  if (root) {
    const img = root.querySelector<HTMLImageElement>('#lb-img')!;
    const caption = root.querySelector<HTMLElement>('#lb-caption')!;
    const counter = root.querySelector<HTMLElement>('#lb-counter')!;
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-lb-prev]')!;
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-lb-next]')!;
    const closeBtn = root.querySelector<HTMLButtonElement>('[data-lb-close]')!;
    const backdrop = root.querySelector<HTMLDivElement>('[data-lb-backdrop]')!;

    let items: Item[] = [];
    let index = 0;
    let prevFocus: Element | null = null;

    const collect = (): Item[] =>
      Array.from(document.querySelectorAll<HTMLElement>('[data-lb]')).map(el => ({
        el,
        src: el.dataset.lbSrc ?? '',
        alt: el.dataset.lbAlt ?? '',
        caption: el.dataset.lbCaption ?? '',
      }));

    const preload = (i: number) => {
      const it = items[i];
      if (!it) return;
      const im = new Image();
      im.src = it.src;
    };

    const show = (i: number) => {
      if (!items.length) return;
      index = ((i % items.length) + items.length) % items.length;
      const it = items[index];
      img.style.opacity = '0';
      const handle = () => {
        img.style.opacity = '1';
        img.removeEventListener('load', handle);
      };
      img.addEventListener('load', handle);
      img.src = it.src;
      img.alt = it.alt;
      caption.textContent = it.caption;
      counter.textContent = `${index + 1} / ${items.length}`;
      // Hide nav arrows when only one item
      const single = items.length <= 1;
      prevBtn.hidden = single;
      nextBtn.hidden = single;
      // preload neighbors
      preload((index + 1) % items.length);
      preload((index - 1 + items.length) % items.length);
    };

    const open = (start: number) => {
      items = collect();
      if (!items.length) return;
      prevFocus = document.activeElement;
      root.hidden = false;
      requestAnimationFrame(() => {
        root.style.opacity = '1';
        root.style.pointerEvents = 'auto';
        root.dataset.state = 'open';
      });
      document.body.style.overflow = 'hidden';
      show(start);
      closeBtn.focus({ preventScroll: true });
    };

    const close = () => {
      root.style.opacity = '0';
      root.style.pointerEvents = 'none';
      root.dataset.state = 'closed';
      document.body.style.overflow = '';
      window.setTimeout(() => {
        root.hidden = true;
        img.src = '';
      }, 200);
      if (prevFocus instanceof HTMLElement) prevFocus.focus({ preventScroll: true });
    };

    // Wire triggers (delegated so dynamically-rendered figures still work)
    document.addEventListener('click', (ev) => {
      const target = (ev.target as HTMLElement).closest<HTMLElement>('[data-lb]');
      if (!target) return;
      ev.preventDefault();
      const all = collect();
      const i = all.findIndex(x => x.el === target);
      items = all;
      open(i >= 0 ? i : 0);
    });

    prevBtn.addEventListener('click', () => show(index - 1));
    nextBtn.addEventListener('click', () => show(index + 1));
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    document.addEventListener('keydown', (ev) => {
      if (root.dataset.state !== 'open') return;
      if (ev.key === 'Escape') { ev.preventDefault(); close(); }
      else if (ev.key === 'ArrowLeft') { ev.preventDefault(); show(index - 1); }
      else if (ev.key === 'ArrowRight') { ev.preventDefault(); show(index + 1); }
    });

    // Touch swipe
    let touchStartX = 0, touchStartY = 0;
    root.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].clientX;
      touchStartY = e.changedTouches[0].clientY;
    }, { passive: true });
    root.addEventListener('touchend', (e) => {
      if (root.dataset.state !== 'open') return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) show(index + 1);
        else show(index - 1);
      }
    }, { passive: true });
  }
</script>
