---
import { Image } from 'astro:assets';
import Stat from './Stat.astro';
import figPrototype from '../assets/report/fig05-longitudinal-cutout.png';
---

<section id="top" class="relative overflow-hidden">
  <!-- Soft UDST-blue wash on the left; resolves to pure white by ~45% across, before the image column. -->
  <div
    class="absolute inset-0"
    style="background:
      radial-gradient(ellipse 45% 80% at 8% 30%, rgba(0, 85, 184, 0.16), transparent 65%),
      radial-gradient(ellipse 25% 45% at 0% 0%, rgba(0, 62, 135, 0.12), transparent 60%),
      linear-gradient(to right, rgba(206, 224, 245, 0.45) 0%, rgba(206, 224, 245, 0.18) 22%, transparent 42%),
      #ffffff;"
  ></div>

  <div class="relative mx-auto max-w-[var(--container-wide)] px-6 lg:px-10 py-20 md:py-28">
    <div class="flex items-center gap-3 mb-10">
      <svg width="22" height="30" viewBox="0 0 33 46" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M6.05 8.75v13.427l8.749 7.37V8.75l-2.87 2.447v12.578l-2.94-2.393V11.197zM14.799 46V32.58L6.05 25.21V46l2.87-2.44V30.981l2.939 2.393v10.184zm2.773-37.25v20.797l8.755-7.37V8.75h-8.755zm5.816 12.632-2.94 2.413V11.197h2.94v10.185zM3.043 4.242h26.915v2.502H3.043zm26.914-1.74H3.043L0 0h33zM23.45 43.56 26.327 46v-3.168l-2.877-2.448v3.175zm-5.878-10.98V46l2.939-2.44v-10.2l2.939-2.393v8.396l2.877 2.448V25.21l-8.755 7.37z" fill="#0055B8"/>
      </svg>
      <p class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)] font-medium">
        University of Doha for Science and Technology
      </p>
    </div>

    <div class="grid lg:grid-cols-[1fr_1.05fr] gap-10 lg:gap-16 items-center">
      <!-- Masthead -->
      <div>
        <p
          lang="ar"
          class="font-serif text-2xl md:text-3xl text-[color:var(--color-ink-soft)] leading-tight"
        >
          التحديث المستدام للمراكب الخشبية التقليدية في قطر
        </p>

        <h1 class="mt-3 font-serif text-4xl md:text-5xl lg:text-6xl leading-[1.04] tracking-tight text-[color:var(--color-ink)]">
          Sustainable Dhows Retrofitting in Qatar
        </h1>

        <div class="mt-7 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs uppercase tracking-[0.16em] text-[color:var(--color-ink-muted)] font-medium">
          <span>Report MOECC-UDST-5</span>
          <span aria-hidden="true">·</span>
          <span>January 2026</span>
          <span aria-hidden="true">·</span>
          <span>Phase 3 / 4</span>
        </div>

        <p class="mt-6 text-base md:text-lg text-[color:var(--color-ink-soft)] leading-relaxed text-pretty">
          A practical, safe, and certifiable framework for retrofitting traditional
          Dhow vessels with electric propulsion — supporting Qatar&rsquo;s low-emission
          maritime transition while preserving its cultural heritage.
        </p>
      </div>

      <!-- 1:5 prototype longitudinal cutout — floats directly on the white hero -->
      <Image
        src={figPrototype}
        alt="Longitudinal cutout of the 1:5 prototype Dhow hull, showing electric propulsion, rudder, and battery compartments"
        widths={[600, 900, 1200, 1600]}
        sizes="(min-width: 1024px) 560px, 92vw"
        class="w-full h-auto lg:-mr-4"
        loading="eager"
        decoding="async"
      />
    </div>

    <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8 max-w-4xl">
      <Stat value="1:5" label="Modular prototype scale" />
      <Stat value="22m" label="Reference vessel (Al Arour)" />
      <Stat value="4" label="Project phases" footnote="2 complete · 2 ongoing" />
      <Stat value="OMAE 2026" label="Peer-reviewed paper" footnote="Tokyo · Safety framework" />
    </div>
  </div>
</section>
