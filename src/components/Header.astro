---
const links = [
  { href: '#background', label: 'Background' },
  { href: '#prototype', label: 'Prototype' },
  { href: '#charging', label: 'Charging' },
  { href: '#live', label: 'Live data' },
  { href: '#vr', label: 'VR' },
  { href: '#safety', label: 'Safety' },
  { href: '#competition', label: 'Competition' },
  { href: '#team', label: 'Team' },
];
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[color:var(--color-paper)]/85 border-b border-[color:var(--color-rule)]">
  <div class="mx-auto max-w-[var(--container-wide)] px-6 lg:px-10 h-16 flex items-center gap-6">
    <a href="#top" class="flex items-center gap-3 group">
      <!-- UDST monogram (real brand asset) -->
      <svg width="22" height="30" viewBox="0 0 33 46" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="shrink-0">
        <path d="M6.05 8.75v13.427l8.749 7.37V8.75l-2.87 2.447v12.578l-2.94-2.393V11.197zM14.799 46V32.58L6.05 25.21V46l2.87-2.44V30.981l2.939 2.393v10.184zm2.773-37.25v20.797l8.755-7.37V8.75h-8.755zm5.816 12.632-2.94 2.413V11.197h2.94v10.185zM3.043 4.242h26.915v2.502H3.043zm26.914-1.74H3.043L0 0h33zM23.45 43.56 26.327 46v-3.168l-2.877-2.448v3.175zm-5.878-10.98V46l2.939-2.44v-10.2l2.939-2.393v8.396l2.877 2.448V25.21l-8.755 7.37z" fill="#0055B8"/>
      </svg>
      <span class="flex flex-col leading-none">
        <span class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-ink-muted)] font-medium">
          UDST &middot; MoECC
        </span>
        <span class="font-serif text-[15px] font-semibold text-[color:var(--color-ink)] tracking-tight mt-0.5">
          Sustainable Dhows
        </span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-6 text-[13px] text-[color:var(--color-ink-soft)] ml-auto">
      {links.map((l) => (
        <a href={l.href} class="hover:text-[color:var(--color-udst-blue)] transition-colors">
          {l.label}
        </a>
      ))}
    </nav>

    <a
      href="#live"
      class="ml-auto lg:ml-0 inline-flex items-center gap-1.5 text-[12px] font-medium px-3 py-1.5 rounded-full bg-[color:var(--color-udst-blue)] text-white hover:bg-[color:var(--color-udst-blue-deep)] transition-colors"
    >
      <span class="relative flex h-1.5 w-1.5">
        <span class="absolute inline-flex h-full w-full rounded-full bg-white opacity-60 animate-ping"></span>
        <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-white"></span>
      </span>
      Live telemetry
    </a>
  </div>
</header>
