---
interface Props {
  value: string;
  label: string;
  footnote?: string;
}
const { value, label, footnote } = Astro.props;
---

<div>
  <div class="font-serif text-3xl md:text-4xl text-[color:var(--color-ink)] tracking-tight">
    {value}
  </div>
  <div class="mt-1 text-sm text-[color:var(--color-ink-soft)]">{label}</div>
  {footnote && (
    <div class="mt-0.5 text-xs text-[color:var(--color-ink-muted)]">{footnote}</div>
  )}
</div>
